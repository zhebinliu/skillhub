# ── 数据库 ───────────────────────────────────────────────
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=change-me-strong-password

# 如果复用外部 postgres,把下面 4 个填上,docker-compose 会优先用
# SKILLHUB_DB_HOST=postgres
# SKILLHUB_DB_PORT=5432
# SKILLHUB_DB_USER=...
# SKILLHUB_DB_PASSWORD=...
# SKILLHUB_DB_NAME=skillhub

# ── 鉴权 ────────────────────────────────────────────────
# 改成随机 32+ 字符
SKILLHUB_JWT_SECRET=change-me-please-use-random-32+-chars

# 初始 admin(首次启动建一次,改了密码就用新密码)
SKILLHUB_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SKILLHUB_BOOTSTRAP_ADMIN_USERNAME=admin
SKILLHUB_BOOTSTRAP_ADMIN_PASSWORD=changeme!

# ── 上传限额 ────────────────────────────────────────────
# 默认 50MB 单包 / 500 文件 / 512KB 单文件预览
# SKILLHUB_MAX_SKILL_SIZE_MB=50
# SKILLHUB_MAX_FILE_COUNT=500

# ── LLM 质检(可选;不配则 LLM 模式跳过,只跑 5 维静态评分)
# 走 OpenAI 兼容接口:
SKILLHUB_LLM_PROVIDER=openai_compat
SKILLHUB_LLM_BASE_URL=https://api.openai.com
SKILLHUB_LLM_API_KEY=
SKILLHUB_LLM_MODEL=gpt-4o-mini

# 或走 Anthropic:
# SKILLHUB_LLM_PROVIDER=anthropic
# SKILLHUB_LLM_BASE_URL=https://api.anthropic.com
# SKILLHUB_LLM_API_KEY=sk-ant-...
# SKILLHUB_LLM_MODEL=claude-opus-4-7

# 调用超时(秒)
# SKILLHUB_LLM_TIMEOUT=90

# Docker 网络名(嵌入到外部 nginx 时,改成跟主 compose 同名网络)
# COMPOSE_NETWORK=shared
